NODE_ENV=development
PORT=30013
# Local development (non-Docker):
DATABASE_URL=postgresql://wyshcare_app:wyshcare_app@localhost:5432/wyshcare
# Docker: overridden by docker-compose.yml environment block to use service name "postgres"
REDIS_URL=redis://redis:6379

# REQUIRED: generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-strong-secret

RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=replace-me

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
OPENAI_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=

LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_HOST=

COOKIE_SECRET=generate-a-random-secret
MASTER_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

CORS_ORIGIN=http://127.0.0.1:3000,http://localhost:3000
APP_BASE_URL=http://127.0.0.1:30013
SHARE_LINK_BASE_URL=https://wyshcare.app/share

STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=/var/lib/wyshcare/uploads
# REQUIRED: generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
STORAGE_SIGNING_SECRET=replace-with-storage-signing-secret
STORAGE_BUCKET=
STORAGE_REGION=ap-south-1
STORAGE_ENDPOINT=
STORAGE_FORCE_PATH_STYLE=false
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
MAX_UPLOAD_BYTES=10485760
UPLOAD_SCAN_COMMAND=

# Supabase — OTP delivery via Supabase Auth (replaces custom SMS OTP when configured)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ABDM (Ayushman Bharat Digital Mission) — Sandbox credentials
ABDM_CLIENT_ID=
ABDM_CLIENT_SECRET=
ABDM_GATEWAY_URL=https://dev.abdm.gov.in

SENTRY_DSN=

OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

RABBITMQ_ENABLED=false
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# SMS OTP delivery — required for production
# Supported: twilio | msg91 | fast2sms
SMS_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_TEMPLATE_ID=

# Firebase Cloud Messaging — legacy server key for fcm.googleapis.com/fcm/send
# Retrieved via Firebase Admin SDK from wyshcare Firebase project
# Firebase Cloud Messaging (HTTP v1 API + Service Account)
FCM_PROJECT_ID=wyshcare
GOOGLE_APPLICATION_CREDENTIALS=.secrets/firebase-service-account.json

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@wyshcare.app
