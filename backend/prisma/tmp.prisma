generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                                                       String                     @id @default(cuid())
  wyshId                                                                   String                     @unique
  phoneNumber                                                              String                     @unique
  email                                                                    String?                    @unique
  fullName                                                                 String
  preferredLanguage                                                        String                     @default("en")
  avatarUrl                                                                String?
  dateOfBirth                                                              DateTime?
  gender                                                                   String?
  bloodGroup                                                               String?
  aadhaarLast4                                                             String?
  abhaAddress                                                              String?                    @unique
  abhaNumberMasked                                                         String?
  emergencyProfile                                                         Json?
  chronicConditions                                                        String[]
  allergiesSummary                                                         String[]
  isPhoneVerified                                                          Boolean                    @default(false)
  status                                                                   VerificationStatus         @default(PENDING)
  deletedAt                                                                DateTime?
  createdAt                                                                DateTime                   @default(now())
  updatedAt                                                                DateTime                   @updatedAt
  tenantId                                                                 String?
  abdmLinkage                                                              ABDMLinkage?
  aiJobs                                                                   AIJob[]
  aiMemories                                                               AIMemoryNode[]
  AbdmAuditLog                                                             AbdmAuditLog[]
  AbdmConsent                                                              AbdmConsent[]
  AbhaProfile                                                              AbhaProfile?
  AdherenceLog                                                             AdherenceLog[]
  adminCredential                                                          AdminCredential?
  Allergy_Allergy_patientIdToUser                                          Allergy[]                  @relation("Allergy_patientIdToUser")
  Allergy_Allergy_verifiedByIdToUser                                       Allergy[]                  @relation("Allergy_verifiedByIdToUser")
  doctorAppointments                                                       Appointment[]              @relation("appointment_doctor_user")
  appointments                                                             Appointment[]              @relation("appointment_patient")
  actorAuditLogs                                                           AuditLog[]                 @relation("actor_audit_logs")
  patientAuditLogs                                                         AuditLog[]                 @relation("patient_audit_logs")
  BillingInvoice                                                           BillingInvoice[]
  CDSAlert_CDSAlert_dismissedByIdToUser                                    CDSAlert[]                 @relation("CDSAlert_dismissedByIdToUser")
  CDSAlert_CDSAlert_patientIdToUser                                        CDSAlert[]                 @relation("CDSAlert_patientIdToUser")
  CareContext                                                              CareContext[]
  CarePlan                                                                 CarePlan[]
  CareTask_CareTask_assignedToIdToUser                                     CareTask[]                 @relation("CareTask_assignedToIdToUser")
  CareTask_CareTask_completedByIdToUser                                    CareTask[]                 @relation("CareTask_completedByIdToUser")
  CareTask_CareTask_patientIdToUser                                        CareTask[]                 @relation("CareTask_patientIdToUser")
  Claim                                                                    Claim[]
  ClinicalDocument_ClinicalDocument_patientIdToUser                        ClinicalDocument[]         @relation("ClinicalDocument_patientIdToUser")
  ClinicalDocument_ClinicalDocument_uploadedByIdToUser                     ClinicalDocument[]         @relation("ClinicalDocument_uploadedByIdToUser")
  ClinicalNote_ClinicalNote_authoredByIdToUser                             ClinicalNote[]             @relation("ClinicalNote_authoredByIdToUser")
  ClinicalNote_ClinicalNote_patientIdToUser                                ClinicalNote[]             @relation("ClinicalNote_patientIdToUser")
  ClinicalNote_ClinicalNote_signedByIdToUser                               ClinicalNote[]             @relation("ClinicalNote_signedByIdToUser")
  ClinicalOrder_ClinicalOrder_completedByIdToUser                          ClinicalOrder[]            @relation("ClinicalOrder_completedByIdToUser")
  ClinicalOrder_ClinicalOrder_orderedByIdToUser                            ClinicalOrder[]            @relation("ClinicalOrder_orderedByIdToUser")
  ClinicalOrder_ClinicalOrder_patientIdToUser                              ClinicalOrder[]            @relation("ClinicalOrder_patientIdToUser")
  Condition_Condition_patientIdToUser                                      Condition[]                @relation("Condition_patientIdToUser")
  Condition_Condition_verifiedByIdToUser                                   Condition[]                @relation("Condition_verifiedByIdToUser")
  grantedConsents                                                          ConsentGrant[]             @relation("consent_recipient")
  ownedConsents                                                            ConsentGrant[]             @relation("consent_owner")
  consultationSessions                                                     ConsultationSession[]
  consultationSummaries                                                    ConsultationSummary[]
  sessions                                                                 DeviceSession[]
  labOrders                                                                DiagnosticOrder[]
  diagnosticReports                                                        DiagnosticReport[]
  DigitalTwin                                                              DigitalTwin?
  DispensingRecord_DispensingRecord_patientIdToUser                        DispensingRecord[]         @relation("DispensingRecord_patientIdToUser")
  DispensingRecord_DispensingRecord_pharmacistIdToUser                     DispensingRecord[]         @relation("DispensingRecord_pharmacistIdToUser")
  doctorProfile                                                            DoctorProfile?
  EligibilityCheck                                                         EligibilityCheck[]
  accessorEmergencyAccesses                                                EmergencyAccess[]          @relation("accessor_emergency_access")
  patientEmergencyAccesses                                                 EmergencyAccess[]          @relation("patient_emergency_access")
  Encounter_Encounter_patientIdToUser                                      Encounter[]                @relation("Encounter_patientIdToUser")
  Encounter_Encounter_providerIdToUser                                     Encounter[]                @relation("Encounter_providerIdToUser")
  FamilyHistory                                                            FamilyHistory[]
  families                                                                 FamilyRelation[]           @relation("family_actor")
  relatedTo                                                                FamilyRelation[]           @relation("family_subject")
  HealthInformationRequest_HealthInformationRequest_patientUserIdToUser    HealthInformationRequest[] @relation("HealthInformationRequest_patientUserIdToUser")
  HealthInformationRequest_HealthInformationRequest_requesterUserIdToUser  HealthInformationRequest[] @relation("HealthInformationRequest_requesterUserIdToUser")
  records                                                                  HealthRecord[]
  Immunization_Immunization_administeredByIdToUser                         Immunization[]             @relation("Immunization_administeredByIdToUser")
  Immunization_Immunization_patientIdToUser                                Immunization[]             @relation("Immunization_patientIdToUser")
  InsurancePolicy                                                          InsurancePolicy[]
  LabResult                                                                LabResult[]
  LabSample                                                                LabSample[]
  LifestyleProfile                                                         LifestyleProfile?
  MedicationAdherenceLog                                                   MedicationAdherenceLog[]
  MedicationAdministration_MedicationAdministration_administeredByIdToUser MedicationAdministration[] @relation("MedicationAdministration_administeredByIdToUser")
  MedicationAdministration_MedicationAdministration_patientIdToUser        MedicationAdministration[] @relation("MedicationAdministration_patientIdToUser")
  MedicationReminder                                                       MedicationReminder[]
  MedicationSchedule                                                       MedicationSchedule[]
  notifications                                                            Notification[]
  NotificationPreference                                                   NotificationPreference[]
  otps                                                                     OtpChallenge[]
  paymentOrders                                                            PaymentOrder[]
  PharmacyCartItem                                                         PharmacyCartItem[]
  medicineOrders                                                           PharmacyOrder[]
  PreAuthorization                                                         PreAuthorization[]
  prescriptions                                                            Prescription[]
  PreventiveRecommendation                                                 PreventiveRecommendation[]
  ProcedureRecord_ProcedureRecord_patientIdToUser                          ProcedureRecord[]          @relation("ProcedureRecord_patientIdToUser")
  ProcedureRecord_ProcedureRecord_performerIdToUser                        ProcedureRecord[]          @relation("ProcedureRecord_performerIdToUser")
  providerProfile                                                          ProviderProfile?
  QueueEntry                                                               QueueEntry[]
  Referral                                                                 Referral[]
  refreshTokens                                                            RefreshToken[]
  RiskPrediction                                                           RiskPrediction[]
  accessLinks                                                              ShareLink[]
  ShiftHandover_ShiftHandover_fromUserIdToUser                             ShiftHandover[]            @relation("ShiftHandover_fromUserIdToUser")
  ShiftHandover_ShiftHandover_toUserIdToUser                               ShiftHandover[]            @relation("ShiftHandover_toUserIdToUser")
  SpecialtyEncounterData_SpecialtyEncounterData_patientIdToUser            SpecialtyEncounterData[]   @relation("SpecialtyEncounterData_patientIdToUser")
  SpecialtyEncounterData_SpecialtyEncounterData_providerIdToUser           SpecialtyEncounterData[]   @relation("SpecialtyEncounterData_providerIdToUser")
  SpecialtyFinding_SpecialtyFinding_patientIdToUser                        SpecialtyFinding[]         @relation("SpecialtyFinding_patientIdToUser")
  SpecialtyFinding_SpecialtyFinding_providerIdToUser                       SpecialtyFinding[]         @relation("SpecialtyFinding_providerIdToUser")
  StaffAssignment                                                          StaffAssignment[]
  SymptomEvent                                                             SymptomEvent[]
  timelineEvents                                                           TimelineEvent[]
  roles                                                                    UserRole[]
  VitalsRecord_VitalsRecord_patientIdToUser                                VitalsRecord[]             @relation("VitalsRecord_patientIdToUser")
  VitalsRecord_VitalsRecord_recordedByIdToUser                             VitalsRecord[]             @relation("VitalsRecord_recordedByIdToUser")
  WearableMetric                                                           WearableMetric[]
  aiRecommendations                                                        AIRecommendation[]
  emergencyProfileData                                                     EmergencyProfile?
  healthAnalytics                                                          HealthAnalytics[]
  healthGoals                                                              HealthGoal[]
  healthGraphNodes                                                         HealthGraphNode[]
  healthScores                                                             HealthScore[]

  @@index([fullName])
  @@index([phoneNumber, status])
  @@index([abhaAddress])
  @@index([createdAt])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  role      Role
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
}

model DeviceSession {
  id                String    @id @default(cuid())
  userId            String
  refreshTokenId    String?
  deviceName        String
  deviceFingerprint String
  ipAddress         String
  userAgent         String
  lastSeenAt        DateTime  @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([deviceFingerprint])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  deviceId  String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AdminCredential {
  userId       String   @id
  passwordHash String
  mfaSecret    String?
  mfaEnabled   Boolean  @default(false)
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpChallenge {
  id           String              @id @default(cuid())
  userId       String?
  phoneNumber  String
  otpHash      String
  purpose      String
  channel      NotificationChannel
  expiresAt    DateTime
  verifiedAt   DateTime?
  attemptCount Int                 @default(0)
  metadata     Json?
  createdAt    DateTime            @default(now())
  user         User?               @relation(fields: [userId], references: [id])

  @@index([phoneNumber, expiresAt])
  @@index([userId])
}

model FamilyRelation {
  id                  String           @id @default(cuid())
  actorUserId         String
  subjectUserId       String
  relationship        RelationshipType
  canViewTimeline     Boolean          @default(false)
  canBookAppointments Boolean          @default(false)
  canOrderMedicines   Boolean          @default(false)
  canUseEmergency     Boolean          @default(true)
  createdAt           DateTime         @default(now())
  actor               User             @relation("family_actor", fields: [actorUserId], references: [id], onDelete: Cascade)
  subject             User             @relation("family_subject", fields: [subjectUserId], references: [id], onDelete: Cascade)

  @@unique([actorUserId, subjectUserId, relationship])
  @@index([subjectUserId])
}

model ProviderProfile {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  registrationNumber     String?
  verificationStatus     VerificationStatus @default(PENDING)
  licenseDocumentUrl     String?
  kycMetadata            Json?
  payoutAccountReference String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DoctorProfile {
  id                   String                @id @default(cuid())
  userId               String                @unique
  specialization       String
  subSpecializations   String[]
  qualifications       String[]
  yearsOfExperience    Int
  registrationNumber   String                @unique
  languages            String[]
  gender               String?
  bio                  String?
  consultationFee      Int
  telemedicineEnabled  Boolean               @default(true)
  inClinicEnabled      Boolean               @default(true)
  approvalStatus       VerificationStatus    @default(PENDING)
  averageRating        Float                 @default(0)
  totalReviews         Int                   @default(0)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  tenantId             String?
  appointments         Appointment[]
  consultationSessions ConsultationSession[]
  clinicMappings       DoctorClinic[]
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  prescriptions        Prescription[]
  QueueEntry           QueueEntry[]

  @@index([specialization, telemedicineEnabled])
  @@index([approvalStatus])
}

model Clinic {
  id                 String             @id @default(cuid())
  name               String
  slug               String             @unique
  description        String?
  phoneNumber        String
  addressLine1       String
  addressLine2       String?
  city               String
  state              String
  pincode            String
  latitude           Decimal?           @db.Decimal(9, 6)
  longitude          Decimal?           @db.Decimal(9, 6)
  languages          String[]
  verificationStatus VerificationStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  tenantId           String?
  email              String?
  facilities         String[]
  logoUrl            String?
  operatingHours     Json?
  services           String[]
  timezone           String             @default("Asia/Kolkata")
  website            String?
  appointments       Appointment[]
  BillingInvoice     BillingInvoice[]
  Claim              Claim[]
  ClinicBranding     ClinicBranding?
  ClinicTemplate     ClinicTemplate[]
  doctors            DoctorClinic[]
  PreAuthorization   PreAuthorization[]
  QueueEntry         QueueEntry[]
  StaffAssignment    StaffAssignment[]

  @@index([city, pincode])
  @@index([verificationStatus])
}

model DoctorClinic {
  id              String        @id @default(cuid())
  doctorId        String
  clinicId        String
  isPrimary       Boolean       @default(false)
  consultationFee Int
  mondaySlots     Json?
  tuesdaySlots    Json?
  wednesdaySlots  Json?
  thursdaySlots   Json?
  fridaySlots     Json?
  saturdaySlots   Json?
  sundaySlots     Json?
  createdAt       DateTime      @default(now())
  clinic          Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor          DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, clinicId])
  @@index([clinicId])
}

model ConsentGrant {
  id                 String        @id @default(cuid())
  ownerUserId        String
  grantedToUserId    String?
  granteeExternalRef String?
  accessLevel        AccessLevel
  accessMethod       AccessMethod
  status             ConsentStatus @default(PENDING)
  purpose            String
  scope              Json
  accessReason       String?
  grantedAt          DateTime?
  expiresAt          DateTime
  revokedAt          DateTime?
  createdAt          DateTime      @default(now())
  auditLogs          AuditLog[]
  grantedToUser      User?         @relation("consent_recipient", fields: [grantedToUserId], references: [id])
  ownerUser          User          @relation("consent_owner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  shareLinks         ShareLink[]

  @@index([ownerUserId, status])
  @@index([grantedToUserId, status])
  @@index([expiresAt, status])
}

model ShareLink {
  id             String        @id @default(cuid())
  ownerUserId    String
  consentGrantId String?
  tokenHash      String        @unique
  accessLevel    AccessLevel
  maxViews       Int           @default(1)
  currentViews   Int           @default(0)
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime      @default(now())
  consentGrant   ConsentGrant? @relation(fields: [consentGrantId], references: [id])
  ownerUser      User          @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, expiresAt])
  @@index([expiresAt, revokedAt])
  @@index([consentGrantId])
}

model EmergencyAccess {
  id             String                @id @default(cuid())
  patientUserId  String
  accessorUserId String?
  reason         EmergencyAccessReason
  geoLatitude    Decimal?              @db.Decimal(9, 6)
  geoLongitude   Decimal?              @db.Decimal(9, 6)
  notes          String?
  expiresAt      DateTime
  createdAt      DateTime              @default(now())
  accessorUser   User?                 @relation("accessor_emergency_access", fields: [accessorUserId], references: [id])
  patientUser    User                  @relation("patient_emergency_access", fields: [patientUserId], references: [id], onDelete: Cascade)

  @@index([patientUserId, createdAt])
  @@index([accessorUserId])
}

model HealthRecord {
  id                String             @id @default(cuid())
  userId            String
  recordType        RecordType
  title             String
  description       String?
  source            String
  sourceReferenceId String?
  storageKey        String?
  mimeType          String?
  fileSize          Int?
  extractedText     String?
  structuredPayload Json?
  encryptedDek      String?
  hash              String?
  fileIv            String?
  fileAuthTag       String?
  version           Int                @default(1)
  recordedAt        DateTime
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  diagnostics       DiagnosticReport[]
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  medications       Medication[]
  prescriptions     Prescription[]
  timelineEvents    TimelineEvent[]

  @@index([userId])
}

model Prescription {
  id                       String                    @id @default(cuid())
  healthRecordId           String?
  patientUserId            String
  doctorProfileId          String?
  appointmentId            String?
  diagnosisSummary         String?
  instructions             String?
  refillDueAt              DateTime?
  createdAt                DateTime                  @default(now())
  consultationId           String?
  diagnosis                Json?
  issuedAt                 DateTime?
  notes                    String?
  status                   PrescriptionStatus        @default(DRAFT)
  tenantId                 String?
  updatedAt                DateTime                  @updatedAt
  DispensingRecord         DispensingRecord[]
  medications              Medication[]
  doctorProfile            DoctorProfile?            @relation(fields: [doctorProfileId], references: [id])
  healthRecord             HealthRecord?             @relation(fields: [healthRecordId], references: [id])
  patientUser              User                      @relation(fields: [patientUserId], references: [id], onDelete: Cascade)
  PrescriptionItem         PrescriptionItem[]
  PrescriptionVerification PrescriptionVerification?

  @@index([patientUserId, createdAt])
  @@index([status])
  @@index([tenantId])
  @@index([doctorProfileId])
  @@index([healthRecordId])
}

model Medication {
  id                     String                   @id @default(cuid())
  prescriptionId         String?
  healthRecordId         String?
  name                   String
  dosage                 String?
  frequency              String?
  durationDays           Int?
  route                  String?
  genericName            String?
  interactionWarnings    String[]
  adherenceStatus        String?
  healthRecord           HealthRecord?            @relation(fields: [healthRecordId], references: [id])
  prescription           Prescription?            @relation(fields: [prescriptionId], references: [id])
  MedicationAdherenceLog MedicationAdherenceLog[]
  MedicationReminder     MedicationReminder[]
  PrescriptionItem       PrescriptionItem[]

  @@index([name])
  @@index([healthRecordId])
  @@index([prescriptionId])
}

model DiagnosticReport {
  id              String       @id @default(cuid())
  healthRecordId  String
  patientUserId   String
  labPartnerId    String?
  reportType      String
  summary         String?
  abnormalMarkers Json?
  trendSnapshot   Json?
  recordedAt      DateTime
  createdAt       DateTime     @default(now())
  healthRecord    HealthRecord @relation(fields: [healthRecordId], references: [id], onDelete: Cascade)
  patientUser     User         @relation(fields: [patientUserId], references: [id], onDelete: Cascade)

  @@index([patientUserId, reportType, recordedAt])
  @@index([healthRecordId])
}

model TimelineEvent {
  id             String            @id @default(cuid())
  userId         String
  healthRecordId String?
  type           TimelineEventType
  title          String
  summary        String
  metadata       Json?
  occurredAt     DateTime
  createdAt      DateTime          @default(now())
  healthRecord   HealthRecord?     @relation(fields: [healthRecordId], references: [id])
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@index([userId, type, occurredAt])
  @@index([type, occurredAt])
  @@index([healthRecordId])
}

model Appointment {
  id                  String               @id @default(cuid())
  patientUserId       String
  doctorProfileId     String
  doctorUserId        String?
  clinicId            String?
  status              AppointmentStatus    @default(REQUESTED)
  consultationMode    ConsultationMode     @default(VIDEO)
  reason              String
  slotStartAt         DateTime
  slotEndAt           DateTime
  bookedAt            DateTime             @default(now())
  paymentOrderId      String?
  consultationRoomId  String?
  tenantId            String?
  clinic              Clinic?              @relation(fields: [clinicId], references: [id])
  doctorProfile       DoctorProfile        @relation(fields: [doctorProfileId], references: [id])
  doctorUser          User?                @relation("appointment_doctor_user", fields: [doctorUserId], references: [id])
  patientUser         User                 @relation("appointment_patient", fields: [patientUserId], references: [id], onDelete: Cascade)
  BillingInvoice      BillingInvoice[]
  consultationSession ConsultationSession?
  QueueEntry          QueueEntry?

  @@index([patientUserId, slotStartAt])
  @@index([doctorProfileId, slotStartAt])
  @@index([doctorUserId, slotStartAt])
  @@index([status, slotStartAt])
  @@index([tenantId])
  @@index([clinicId])
}

model ConsultationSession {
  id                     String                   @id @default(cuid())
  appointmentId          String                   @unique
  doctorProfileId        String
  patientUserId          String
  mode                   ConsultationMode
  livekitRoomName        String?
  waitingRoomOpenAt      DateTime?
  startedAt              DateTime?
  endedAt                DateTime?
  recordingReference     String?
  chatTranscript         Json?
  notes                  String?
  aiSummary              String?
  createdAt              DateTime                 @default(now())
  tenantId               String?
  ConsultationRecording  ConsultationRecording[]
  ConsultationSOAP       ConsultationSOAP[]
  appointment            Appointment              @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  doctorProfile          DoctorProfile            @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  patientUser            User                     @relation(fields: [patientUserId], references: [id], onDelete: Cascade)
  ConsultationTranscript ConsultationTranscript[]

  @@index([patientUserId, createdAt])
  @@index([doctorProfileId, createdAt])
}

model ConsultationSummary {
  id              String   @id @default(cuid())
  userId          String
  title           String
  summary         String
  followUpActions String[]
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PaymentOrder {
  id                  String        @id @default(cuid())
  userId              String
  providerReference   String?       @unique
  orderType           String
  status              PaymentStatus @default(CREATED)
  currency            String        @default("INR")
  amount              Int
  taxAmount           Int           @default(0)
  platformFeeAmount   Int           @default(0)
  providerShareAmount Int           @default(0)
  refundAmount        Int           @default(0)
  metadata            Json?
  capturedAt          DateTime?
  createdAt           DateTime      @default(now())
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}

model PharmacyPartner {
  id                 String              @id @default(cuid())
  name               String
  phoneNumber        String
  city               String
  state              String
  pincode            String
  latitude           Decimal?            @db.Decimal(9, 6)
  longitude          Decimal?            @db.Decimal(9, 6)
  verificationStatus VerificationStatus  @default(PENDING)
  supportsDelivery   Boolean             @default(true)
  createdAt          DateTime            @default(now())
  address            String?
  deliveryRadiusKm   Int?                @default(10)
  isActive           Boolean             @default(true)
  logoUrl            String?
  tenantId           String?
  updatedAt          DateTime            @default(now())
  PharmacyCartItem   PharmacyCartItem[]
  PharmacyInventory  PharmacyInventory[]
  orders             PharmacyOrder[]
  ProcurementOrder   ProcurementOrder[]

  @@index([city, pincode])
  @@index([isActive, verificationStatus])
  @@index([tenantId])
}

model PharmacyOrder {
  id                String           @id @default(cuid())
  userId            String
  partnerId         String?
  prescriptionId    String?
  status            OrderStatus      @default(DRAFT)
  quotedTotal       Int?
  deliveryAddress   Json
  medicinePayload   Json
  fulfillmentNotes  String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  cancelReason      String?
  cancelledAt       DateTime?
  consultationId    String?
  deliveredAt       DateTime?
  deliveryPartner   String?
  estimatedDelivery DateTime?
  paymentOrderId    String?
  tenantId          String?
  trackingUrl       String?
  partner           PharmacyPartner? @relation(fields: [partnerId], references: [id])
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([partnerId, status])
  @@index([prescriptionId])
  @@index([tenantId])
}

model DiagnosticsPartner {
  id                 String             @id @default(cuid())
  name               String
  city               String
  pincode            String
  homeCollection     Boolean            @default(false)
  accreditation      String?
