{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/backend/src/main.js",
    "start:dev": "ts-node --project tsconfig.json src/main.ts",
    "start:prod": "node dist/backend/src/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "npm run compile:tests && node --test dist-test/backend/src/test/*.spec.js",
    "test:unit": "npm run compile:tests && node --test dist-test/backend/src/test/*.spec.js",
    "test:integration": "npm run compile:tests && echo 'Integration tests require Docker — run: docker compose -f ../infra/test/docker-compose.test.yml up -d'",
    "test:e2e": "npm run compile:tests && echo 'E2E tests require Docker — run: docker compose -f ../infra/test/docker-compose.test.yml up -d' && node --test dist-test/backend/src/test/e2e/*.e2e-spec.js",
    "compile:tests": "tsc --project tsconfig.test.json",
    "format": "prettier --write \"src/**/*.ts\"",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:seed": "node prisma/seed.js",
    "prisma:seed:clinical": "node prisma/seed-clinical.js",
    "prisma:seed:synthea": "node prisma/seed-synthea.js",
    "prisma:seed:templates": "node prisma/seed-notification-templates.js",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "import:fhir": "ts-node scripts/import-fhir.ts",
    "import:synthea": "ts-node scripts/import-synthea.ts",
    "import:demo": "ts-node scripts/import-demo-data.ts"
  },
  "dependencies": {
    "@apollo/server": "^5.1.0",
    "@as-integrations/express5": "^1.1.2",
    "@aws-sdk/client-s3": "^3.901.0",
    "@aws-sdk/s3-request-presigner": "^3.901.0",
    "@golevelup/nestjs-rabbitmq": "^5.7.0",
    "@google/generative-ai": "^0.24.1",
    "@nestjs/apollo": "^13.2.1",
    "@nestjs/common": "^11.1.8",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.8",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/graphql": "^13.2.0",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/platform-socket.io": "^11.1.8",
    "@nestjs/swagger": "^11.2.1",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^11.1.8",
    "@opentelemetry/api": "^1.9.0",
    "@prisma/client": "^6.19.1",
    "@sentry/node": "^10.49.0",
