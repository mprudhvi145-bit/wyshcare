    "graphql": "^16.12.0",
    "graphql-depth-limit": "^1.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "livekit-server-sdk": "^2.13.1",
    "nodemailer": "^7.0.13",
    "openai": "^4.104.0",
    "otplib": "^12.0.1",
