{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": false,
    "noEmit": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@shared/*": [
        "../shared/src/*"
      ],
      "@wyshcare/shared": [
        "../shared/src/index.ts"
      ],
      "@wyshcare/shared/*": [
        "../shared/src/*"
      ]
    },
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ],
  "_wyshcare": {
    "product": "WyshCare Healthcare Operating System",
    "brand": "WYSH",
    "founder": "Vimarshak Prudhvi",
    "file": "frontend/tsconfig.json",
    "last_reviewed": "2026-06-12"
  }
}
