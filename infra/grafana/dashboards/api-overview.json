{
  "title": "WyshCare API Overview",
  "version": 1,
  "panels": [
    {
      "title": "Request Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(wyshcare_http_requests_total[5m])",
          "legendFormat": "requests/s"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      }
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(wyshcare_http_request_errors_total[5m]) / rate(wyshcare_http_requests_total[5m])",
          "legendFormat": "error ratio"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      }
    },
    {
      "title": "P95 Latency",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(wyshcare_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      }
    },
    {
      "title": "Auth Events",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(wyshcare_auth_events_total)",
          "legendFormat": "total"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 8
      }
    },
    {
      "title": "Health Checks",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(wyshcare_health_checks_total)",
          "legendFormat": "total"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 8
      }
    },
    {
      "title": "Queue Depth",
      "type": "bargauge",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "wyshcare_queue_depth",
          "legendFormat": "{{queue}}"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 8
      }
    }
  ],
  "schemaVersion": 39,
  "_wyshcare": {
    "product": "WyshCare Healthcare Operating System",
    "brand": "WYSH",
    "founder": "Vimarshak Prudhvi",
    "file": "infra/grafana/dashboards/api-overview.json",
    "last_reviewed": "2026-06-12"
  }
}
