model ConsentAudit {
  id             String   @id @default(cuid())
  consentGrantId String
  actorUserId    String
  action         String   @db.VarChar(50) // GRANTED, REVOKED, EXPIRED, ACCESSED, EMERGENCY_ACCESS
  ipAddress      String?  @db.VarChar(45)
  geoRegion      String?  @db.VarChar(100)
  userAgent      String?  @db.VarChar(512)
  metadata       Json?
  createdAt      DateTime @default(now())

  @@map("consent_audits")
}

// ------------------------------------------------------------
// Encrypted Vault — Document storage with classification
// ------------------------------------------------------------
enum DocumentCategory {
  Prescription
  LabReport
  DischargeSummary
  Radiology
  Vaccination
  Insurance
  Claims
  MedicalBills
  WellnessRecord
  Other
}

model HealthDocument {
  id              String           @id @default(cuid())
  userId          String
  category        DocumentCategory
  fileName        String
  contentType     String           @db.VarChar(100)
  storageKey      String           @unique // MinIO/S3 key
  encrypted       Boolean          @default(true)
  encryptionContext String?        // Context for derived encryption key
  fileHash        String?          @db.VarChar(64) // SHA-256 for integrity
  fileSize        Int
  metadata        Json?
  isDeleted       Boolean          @default(false)
  uploadedAt      DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  versions HealthDocumentVersion[]
  shares   DocumentShare[]

  @@map("health_documents")
}

model HealthDocumentVersion {
  id              String  @id @default(cuid())
  documentId      String
  document        HealthDocument @relation(fields: [documentId], references: [id])
  versionNumber   Int
  storageKey      String
  fileHash        String?  @db.VarChar(64)
  fileSize        Int
  uploadedAt      DateTime @default(now())

  @@unique([documentId, versionNumber])
  @@map("health_document_versions")
}

model DocumentShare {
  id            String   @id @default(cuid())
  documentId    String
  document      HealthDocument @relation(fields: [documentId], references: [id])
  sharedWithUserId String?
  accessToken   String   @unique
  expiresAt     DateTime
  accessCount   Int      @default(0)
  lastAccessedAt DateTime?
  createdAt     DateTime @default(now())

  @@map("document_shares")
}

