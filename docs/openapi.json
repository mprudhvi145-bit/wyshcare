{
  "openapi": "3.0.0",
  "info": {
    "title": "WyshCare API",
    "description": "Consumer healthcare infrastructure platform APIs",
    "version": "1.0.0",
    "contact": {
      "name": "WyshCare Engineering"
    }
  },
  "servers": [
    {
      "url": "https://api.wyshcare.com/api/v1",
      "description": "Production"
    },
    {
      "url": "http://localhost:3001/api/v1",
      "description": "Local Development"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {},
          "error": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RequestOtpDto": {
        "type": "object",
        "required": [
          "phoneNumber",
          "purpose"
        ],
        "properties": {
          "phoneNumber": {
            "type": "string",
            "example": "+919876543210"
          },
          "purpose": {
            "type": "string",
            "enum": [
              "LOGIN",
              "REGISTER",
              "ACCESS_SHARE"
            ]
          }
        }
      },
      "VerifyOtpDto": {
        "type": "object",
        "required": [
          "phoneNumber",
          "otpCode",
          "deviceName"
        ],
        "properties": {
          "phoneNumber": {
            "type": "string",
            "example": "+919876543210"
          },
          "otpCode": {
            "type": "string",
            "minLength": 6,
            "maxLength": 6
          },
          "deviceName": {
            "type": "string",
            "example": "iPhone 16 Pro"
          },
          "fullName": {
            "type": "string"
          }
        }
      },
      "RefreshSessionDto": {
        "type": "object",
        "required": [
          "refreshToken"
        ],
        "properties": {
          "refreshToken": {
            "type": "string"
          },
          "deviceName": {
            "type": "string"
          }
        }
      },
      "AuthSession": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          },
          "expiresIn": {
            "type": "integer"
          },
          "user": {
            "$ref": "#/components/schemas/UserProfile"
          }
        }
      },
      "UserProfile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "phoneNumber": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreatePrescriptionDto": {
        "type": "object",
        "required": [
          "patientUserId",
          "items"
        ],
        "properties": {
          "patientUserId": {
            "type": "string",
            "format": "uuid"
          },
          "consultationId": {
            "type": "string",
            "format": "uuid"
          },
          "diagnosis": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PrescriptionItemDto"
            }
          }
        }
      },
      "PrescriptionItemDto": {
        "type": "object",
        "required": [
          "drugId",
          "dosage",
          "frequency",
          "duration"
        ],
        "properties": {
          "drugId": {
            "type": "string",
            "format": "uuid"
          },
          "drugName": {
            "type": "string"
          },
          "dosage": {
            "type": "string"
          },
          "frequency": {
            "type": "string"
          },
          "duration": {
            "type": "string"
          },
          "route": {
            "type": "string"
          },
          "instructions": {
            "type": "string"
          },
          "quantity": {
            "type": "integer"
          }
        }
      },
      "IssuePrescriptionDto": {
        "type": "object",
        "properties": {
          "pharmacyPartnerId": {
            "type": "string",
            "format": "uuid"
          },
          "sendToPharmacy": {
            "type": "boolean"
          },
          "signatureData": {
            "type": "string"
          }
        }
      },
      "Prescription": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "patientUserId": {
            "type": "string",
            "format": "uuid"
          },
          "doctorProfileId": {
            "type": "string",
            "format": "uuid"
          },
          "consultationId": {
            "type": "string",
            "format": "uuid"
          },
          "status": {
            "type": "string",
            "enum": [
              "DRAFT",
              "ISSUED",
              "DISPENSED",
              "CANCELLED",
              "EXPIRED"
            ]
          },
          "diagnosis": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "qrHash": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PrescriptionItemDto"
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "issuedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Appointment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "patientUserId": {
            "type": "string",
            "format": "uuid"
          },
          "doctorProfileId": {
            "type": "string",
            "format": "uuid"
          },
          "scheduledAt": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "CONFIRMED",
              "CANCELLED",
              "COMPLETED",
              "NO_SHOW"
            ]
          },
          "mode": {
            "type": "string",
            "enum": [
              "VIDEO",
              "AUDIO",
              "IN_PERSON",
              "CHAT"
            ]
          },
          "reasonForVisit": {
            "type": "string"
          }
        }
      },
      "CreateAppointmentDto": {
        "type": "object",
        "required": [
          "doctorProfileId",
          "scheduledAt"
        ],
        "properties": {
          "doctorProfileId": {
            "type": "string",
            "format": "uuid"
          },
          "scheduledAt": {
            "type": "string",
            "format": "date-time"
          },
          "mode": {
            "type": "string",
            "enum": [
              "VIDEO",
              "AUDIO",
              "IN_PERSON",
              "CHAT"
            ]
          },
          "reasonForVisit": {
            "type": "string"
          },
          "symptoms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "DoctorProfile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "registrationNumber": {
            "type": "string"
          },
          "specializations": {
            "type": "array",
            "items": {
