{
  "name": "wyshcare",
  "version": "1.0.0-alpha",
  "private": true,
  "description": "WyshCare Healthcare Operating System",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev:backend": "pnpm --filter backend start:dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build:backend": "pnpm --filter backend build",
    "build:frontend": "pnpm --filter frontend build",
    "build:shared": "pnpm --filter shared build",
    "build:all": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "prisma:generate": "pnpm --filter backend prisma:generate",
    "prisma:migrate": "pnpm --filter backend prisma:migrate:deploy",
    "prisma:seed": "pnpm --filter backend prisma:seed",
    "prisma:studio": "pnpm --filter backend prisma:studio",
    "clean": "pnpm -r exec rm -rf dist .next .dart_tool"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
